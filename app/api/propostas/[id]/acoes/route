import { NextRequest, NextResponse } from "next/server";
import { createClient } from "../../../../../lib/supabase/server";

export async function POST(
  request: NextRequest,
  context: { params: { id: string } }
) {
  try {
    const supabase = await createClient();

    const propostaId = context.params.id;

    const body = await request.json();

    const {
      acao,
      observacao,
      usuario_nome
    } = body;

    if (!acao) {
      return NextResponse.json(
        { error: "Ação não informada" },
        { status: 400 }
      );
    }

    // Buscar proposta atual
    const { data: proposta, error: propostaError } =
      await supabase
        .from("propostas")
        .select("*")
        .eq("id", propostaId)
        .single();

    if (propostaError || !proposta) {
      return NextResponse.json(
        { error: "Proposta não encontrada" },
        { status: 404 }
      );
    }

    // Atualizar status da proposta
    const { error: updateError } =
      await supabase
        .from("propostas")
        .update({
          status: acao,
          atualizado_em: new Date().toISOString()
        })
        .eq("id", propostaId);

    if (updateError) {
      return NextResponse.json(
        { error: updateError.message },
        { status: 500 }
      );
    }

    // Registrar histórico da ação
    const { error: historicoError } =
      await supabase
        .from("propostas_historico")
        .insert({
          proposta_id: propostaId,
          acao: acao,
          observacao: observacao || null,
          usuario_nome: usuario_nome || "Sistema",
          criado_em: new Date().toISOString()
        });

    if (historicoError) {
      return NextResponse.json(
        { error: historicoError.message },
        { status: 500 }
      );
    }

    return NextResponse.json({
      success: true,
      message: "Ação registrada com sucesso"
    });

  } catch (error: any) {
    return NextResponse.json(
      {
        error: error.message || "Erro interno"
      },
      { status: 500 }
    );
  }
}