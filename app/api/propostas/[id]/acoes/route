import { NextRequest, NextResponse } from "next/server";

type StatusProposta =
  | "rascunho"
  | "em_analise"
  | "pronta_para_envio"
  | "enviada"
  | "em_negociacao"
  | "aprovada"
  | "recusada"
  | "emitida"
  | "pos_venda";

type AcaoBody = {
  acao: "alterar_status" | "registrar_observacao";
  status?: StatusProposta;
  observacao?: string;
  usuario?: string;
};

type RouteContext = {
  params: Promise<{
    id: string;
  }>;
};

function agoraFormatado() {
  const agora = new Date();

  return new Intl.DateTimeFormat("pt-BR", {
    dateStyle: "short",
    timeStyle: "short",
  }).format(agora);
}

function statusLabel(status: StatusProposta) {
  const mapa: Record<StatusProposta, string> = {
    rascunho: "Rascunho",
    em_analise: "Em análise",
    pronta_para_envio: "Pronta para envio",
    enviada: "Enviada",
    em_negociacao: "Em negociação",
    aprovada: "Aprovada",
    recusada: "Recusada",
    emitida: "Emitida",
    pos_venda: "Pós-venda",
  };

  return mapa[status];
}

export async function GET(_: NextRequest, context: RouteContext) {
  const { id } = await context.params;

  return NextResponse.json({
    sucesso: true,
    mensagem: "Rota de ações da proposta disponível.",
    propostaId: id,
    metodos: ["GET", "POST"],
    exemplos: {
      alterar_status: {
        acao: "alterar_status",
        status: "aprovada",
        usuario: "Ana Paula",
      },
      registrar_observacao: {
        acao: "registrar_observacao",
        observacao: "Cliente solicitou ajuste no prêmio.",
        usuario: "Renato Silva",
      },
    },
  });
}

export async function POST(request: NextRequest, context: RouteContext) {
  try {
    const { id } = await context.params;
    const body = (await request.json()) as AcaoBody;

    if (!body?.acao) {
      return NextResponse.json(
        {
          sucesso: false,
          erro: "Ação não informada.",
        },
        { status: 400 }
      );
    }

    const usuario = body.usuario?.trim() || "Sistema";

    if (body.acao === "alterar_status") {
      if (!body.status) {
        return NextResponse.json(
          {
            sucesso: false,
            erro: "Status não informado.",
          },
          { status: 400 }
        );
      }

      const registro = {
        propostaId: id,
        tipo: "STATUS_ALTERADO",
        statusNovo: body.status,
        statusLabel: statusLabel(body.status),
        usuario,
        data: agoraFormatado(),
        descricao: `Status alterado para ${statusLabel(body.status)}.`,
      };

      console.log("AÇÃO STATUS:", registro);

      return NextResponse.json({
        sucesso: true,
        mensagem: "Status alterado com sucesso.",
        registro,
      });
    }

    if (body.acao === "registrar_observacao") {
      const observacao = body.observacao?.trim();

      if (!observacao) {
        return NextResponse.json(
          {
            sucesso: false,
            erro: "Observação não informada.",
          },
          { status: 400 }
        );
      }

      const registro = {
        propostaId: id,
        tipo: "OBSERVACAO",
        usuario,
        data: agoraFormatado(),
        descricao: observacao,
      };

      console.log("AÇÃO OBSERVAÇÃO:", registro);

      return NextResponse.json({
        sucesso: true,
        mensagem: "Observação registrada com sucesso.",
        registro,
      });
    }

    return NextResponse.json(
      {
        sucesso: false,
        erro: "Ação inválida.",
      },
      { status: 400 }
    );
  } catch (error) {
    console.error("Erro na API de ações:", error);

    return NextResponse.json(
      {
        sucesso: false,
        erro: "Erro interno ao processar ação.",
      },
      { status: 500 }
    );
  }
}